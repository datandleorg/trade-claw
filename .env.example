# Kite Connect API credentials (from https://kite.trade)
# Copy to .env and fill in your values. Do not commit .env.
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
# Optional: access token for Celery worker / headless (same machine as Streamlit, or Docker worker).
# KITE_ACCESS_TOKEN=
# Optional: where Streamlit saves login JSON (default: project root `.kite_session.json`). Docker Compose sets
# `/app/data/.kite_session.json` so Streamlit + celery-worker share the same file on the named volume.
# KITE_SESSION_FILE=/app/data/.kite_session.json

# ngrok for Docker Compose internet exposure
# Required for the `ngrok` compose service
# NGROK_AUTHTOKEN=your_ngrok_authtoken

# F&O Options page — where JSON run snapshots are written when you change parameters (for later analysis)
# FO_OPTIONS_RUNS_DIR=./data/fo_options_runs

# --- Trading defaults (all UI pages + workers; read at call time in trade_claw/env_trading_params.py) ---
# Intraday home / reports: EMA envelope half-width each side as decimal (default 0.003 = 0.3%). Not the same knob as mock/F&O below.
# INTRADAY_ENVELOPE_DECIMAL=0.003
# Mock engine + F&O Options + F&O Agent: spot envelope bandwidth each side of 20-EMA (decimal). Default 0.25 = 25% / side.
# MOCK_AGENT_ENVELOPE_PCT=0.25
# Option target/stop: **MOCK_ENGINE_OPTION_*** (whole-number %, e.g. 25) take precedence when set; else **FO_OPTION_*** as decimal fraction of premium (e.g. 0.25 = +25% target; 0.10 = −10% stop; 0 = no stop).
# MOCK_ENGINE_OPTION_TARGET_PCT=25
# MOCK_ENGINE_OPTION_STOP_PCT=25
# FO_OPTION_TARGET_PCT=0.25
# FO_OPTION_STOP_LOSS_PCT=0.10

# F&O Agent page — OpenAI (mock trades only; no live orders via API tools)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: override model (default below)
OPENAI_MODEL=gpt-5.4-mini

# F&O Agent logging: DEBUG | INFO | WARNING (default INFO) — see stderr / terminal running Streamlit
# FO_AGENT_LOG_LEVEL=INFO

# F&O Agent — optional Zerodha Kite MCP (search_instruments / get_historical_data for tools)
# When enabled, the agent spawns the MCP client (stdio by default: npx mcp-remote https://mcp.kite.trade/mcp).
# KITE_API_KEY / KITE_ACCESS_TOKEN are passed to the child env when you set them here or log in via the app.
# KITE_MCP_ENABLED=1
# Optional JSON array of CLI args (default: ["mcp-remote","https://mcp.kite.trade/mcp"])
# KITE_MCP_ARGS=["mcp-remote","https://mcp.kite.trade/mcp"]
# Optional: MCP command (default npx)
# KITE_MCP_COMMAND=npx
# Optional streamable HTTP transport instead of stdio:
# KITE_MCP_STREAMABLE_URL=https://example.com/mcp
# KITE_MCP_HTTP_HEADERS_JSON={}
# KITE_MCP_HTTP_TIMEOUT=120
# KITE_MCP_SEARCH_LIMIT=500
# Append every MCP tools/call (name, arguments, parsed output) as JSON Lines — useful for debugging
# KITE_MCP_TOOL_OUTPUT_FILE=./logs/kite_mcp_tools.jsonl
# Optional: cap serialized size of the `output` field only (characters)
# KITE_MCP_TOOL_OUTPUT_MAX_CHARS=500000

# Task API + Celery (FastAPI: uvicorn trade_claw.api_server:app)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# TASK_DB_PATH=./data/tasks.db
# Tasks: POST /api/tasks/start — `name` stream_demo (1s ticks) or llm_joke_agent (OpenAI jokes every `interval_seconds`, default 10; uses OPENAI_API_KEY / OPENAI_MODEL).
# Purge broker (clears stuck messages): POST /api/celery/purge-queues or `uv run celery -A trade_claw.celery_app purge -f`
# If old Beat tasks keep appearing: `pgrep -af celery` — stop any extra `celery beat` / `worker --beat` using this Redis.

# --- Autonomous mock AI engine (Nifty options, Celery Beat IST Mon–Fri 09:00–15:59 tick; task guards NSE window) ---
# SQLite WAL: mock trades + LangGraph checkpoints (same file). Streamlit **Mock AI engine** page reads this DB.
# MOCK_TRADES_DB_PATH=./data/mock_engine.db
# Optional: worker token if not using Streamlit-written session file (same machine: log in once via Streamlit → `.kite_session.json`).
# KITE_ACCESS_TOKEN=
# Envelope: see **Trading defaults** block above (`MOCK_AGENT_ENVELOPE_PCT`).
# Slippage (option premium points) sampled uniformly each fill
# MOCK_AGENT_SLIPPAGE_LO=0.5
# MOCK_AGENT_SLIPPAGE_HI=1.0
# Optional: store last N 1m option bars as JSON at mock entry/exit for later replay in Streamlit Analytics (`0` = disable)
# MOCK_ENGINE_SNAPSHOT_BARS=60
# Which NSE index keys to scan each graph run (comma-separated). Valid: NIFTY,BANKNIFTY,FINNIFTY,MIDCPNIFTY,NIFTYNXT50 — same as F&O index list. Default = all five. First index in list with an envelope breakout on the latest bar wins for that tick (up to one spot fetch per key per run when flat).
# MOCK_ENGINE_UNDERLYINGS=NIFTY,BANKNIFTY,FINNIFTY,MIDCPNIFTY,NIFTYNXT50
# Option stop/target %: see **Trading defaults** block (`MOCK_ENGINE_OPTION_*` / `FO_OPTION_*`). Legacy stop name:
# MOCK_ENGINE_STOP_LOSS_CLAMP_PCT=25
# Colored `[mock_market_scan]` logs in Celery worker TTY (`0` / `false` to disable; respects NO_COLOR).
# MOCK_ENGINE_LOG_COLOR=1
# Run (three terminals): Redis, `uv run celery -A trade_claw.celery_app worker --loglevel=info`, `uv run celery -A trade_claw.celery_app beat --loglevel=info`
