# Kite Connect API credentials (from https://kite.trade)
# Copy to .env and fill in your values. Do not commit .env.
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# F&O Options page — where JSON run snapshots are written when you change parameters (for later analysis)
# FO_OPTIONS_RUNS_DIR=./data/fo_options_runs

# F&O mock options (F&O Options page + F&O Agent mock exit math)
# Premium target: exit when bar high >= entry × (1 + FO_OPTION_TARGET_PCT). Default 0.25 = +25%.
# FO_OPTION_TARGET_PCT=0.25
# Stop loss: exit when bar low <= entry × (1 − FO_OPTION_STOP_LOSS_PCT). Default 0.15 = −15%. Set 0 to disable.
# FO_OPTION_STOP_LOSS_PCT=0.15

# F&O Agent page — OpenAI (mock trades only; no live orders via API tools)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: override model (default below)
OPENAI_MODEL=gpt-5.4-mini

# F&O Agent logging: DEBUG | INFO | WARNING (default INFO) — see stderr / terminal running Streamlit
# FO_AGENT_LOG_LEVEL=INFO

# F&O Agent — optional Zerodha Kite MCP (search_instruments / get_historical_data for tools)
# When enabled, the agent spawns the MCP client (stdio by default: npx mcp-remote https://mcp.kite.trade/mcp).
# KITE_API_KEY / KITE_ACCESS_TOKEN are passed to the child env when you set them here or log in via the app.
# KITE_MCP_ENABLED=1
# Optional JSON array of CLI args (default: ["mcp-remote","https://mcp.kite.trade/mcp"])
# KITE_MCP_ARGS=["mcp-remote","https://mcp.kite.trade/mcp"]
# Optional: MCP command (default npx)
# KITE_MCP_COMMAND=npx
# Optional streamable HTTP transport instead of stdio:
# KITE_MCP_STREAMABLE_URL=https://example.com/mcp
# KITE_MCP_HTTP_HEADERS_JSON={}
# KITE_MCP_HTTP_TIMEOUT=120
# KITE_MCP_SEARCH_LIMIT=500
# Append every MCP tools/call (name, arguments, parsed output) as JSON Lines — useful for debugging
# KITE_MCP_TOOL_OUTPUT_FILE=./logs/kite_mcp_tools.jsonl
# Optional: cap serialized size of the `output` field only (characters)
# KITE_MCP_TOOL_OUTPUT_MAX_CHARS=500000

# Task API + Celery (FastAPI: uvicorn trade_claw.api_server:app)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# TASK_DB_PATH=./data/tasks.db
# Tasks: POST /api/tasks/start — `name` stream_demo (1s ticks) or llm_joke_agent (OpenAI jokes every `interval_seconds`, default 10; uses OPENAI_API_KEY / OPENAI_MODEL).
# Purge broker (clears stuck messages): POST /api/celery/purge-queues or `uv run celery -A trade_claw.celery_app purge -f`
# If old Beat tasks keep appearing: `pgrep -af celery` — stop any extra `celery beat` / `worker --beat` using this Redis.
